<Window x:Class="ChatApp.Client.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ChatApp.Client.Converters"
        Title="{Binding CurrentUsername, StringFormat='ChatApp — {0}'}"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:IsOwnMessageConverter x:Key="IsOwnMessageConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT: Room List ── -->
        <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="0,0,1,0">
            <DockPanel Margin="10">

                <TextBlock DockPanel.Dock="Top"
                           Text="Rooms" FontSize="16" FontWeight="Bold"
                           Margin="0,0,0,10" />

                <!-- Create room -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <TextBox Text="{Binding NewRoomName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="4" Margin="0,0,0,5">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding CreateRoomCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="+ New Room"
                            Command="{Binding CreateRoomCommand}"
                            Padding="4" />
                </StackPanel>

                <!-- Room list -->
                <ListBox ItemsSource="{Binding Rooms}"
                         SelectedItem="{Binding SelectedRoom}"
                         Margin="0,0,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MemberCount, StringFormat='{}{0} members'}"
                                           FontSize="11" Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── RIGHT: Chat Area ── -->
        <DockPanel Grid.Column="1" Margin="10">

            <!-- Status bar -->
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding ConnectionStatus}"
                       FontSize="11" Foreground="Gray"
                       Margin="0,0,0,10" />

            <!-- Message input -->
            <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8" FontSize="14"
                         Margin="0,0,5,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1"
                        Content="Send"
                        Command="{Binding SendMessageCommand}"
                        Padding="8" FontSize="14" />
            </Grid>

            <!-- Messages -->
            <ListBox x:Name="MessagesListBox"
                     ItemsSource="{Binding Messages}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6" Margin="2" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F0F0F0" />
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource IsOwnMessageConverter}">
                                                    <Binding Path="SenderName" />
                                                    <Binding Path="DataContext.CurrentUsername"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Background" Value="#DCF8C6" />
                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="{Binding SenderName}"
                                               FontWeight="Bold" FontSize="12" />
                                    <TextBlock Text="{Binding SentAt, StringFormat='{}{0:HH:mm}'}"
                                               FontSize="11" Foreground="Gray"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                                <TextBlock Text="{Binding Content}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>